{
  "name": "Switchboard Charcoal",
  "type": "dark",
  "colors": {
    "editor.background": "#0f0f0f",
    "editor.foreground": "#e2e8f0",
    "sideBar.background": "#111111",
    "sideBar.foreground": "#8b949e",
    "activityBar.background": "#0a0a0a",
    "activityBar.foreground": "#e2e8f0",
    "statusBar.background": "#0a0a0a",
    "statusBar.foreground": "#8b949e",
    "titleBar.activeBackground": "#0a0a0a",
    "titleBar.activeForeground": "#8b949e",
    "panel.background": "#111111",
    "tab.activeBackground": "#0f0f0f",
    "tab.inactiveBackground": "#0a0a0a",
    "tab.activeForeground": "#e2e8f0",
    "tab.inactiveForeground": "#8b949e",
    "editorGroupHeader.tabsBackground": "#0a0a0a",
    "focusBorder": "#58a6ff66",
    "list.activeSelectionBackground": "#58a6ff1a",
    "list.hoverBackground": "#ffffff0d",
    "input.background": "#1a1a1a",
    "dropdown.background": "#1a1a1a",
    "button.background": "#58a6ff",
    "badge.background": "#58a6ff",
    "editorLineNumber.foreground": "#484f58",
    "editorCursor.foreground": "#58a6ff",
    "scrollbarSlider.background": "#ffffff14",
    "editorWidget.background": "#1c1c1c",
    "quickInput.background": "#1c1c1c",
    "notifications.background": "#1c1c1c",
    "terminal.background": "#0a0a0a",
    "widget.border": "#ffffff12",
    "panel.border": "#ffffff12",
    "sideBar.border": "#ffffff12",
    "editorGroup.border": "#ffffff12",
    "editor.selectionBackground": "#264f78",
    "editor.lineHighlightBackground": "#ffffff08",
    "editorBracketMatch.background": "#58a6ff26",
    "editorBracketMatch.border": "#58a6ff66",
    "editorIndentGuide.background1": "#ffffff10"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#6a737d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#e2e8f0"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": {
        "foreground": "#d2a8ff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.type",
        "support.class",
        "storage.type.class"
      ],
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#e2e8f0"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7ee787"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#d2a8ff"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#79c0ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#8b949e"
      }
    }
  ],
  "semanticHighlighting": true
}
