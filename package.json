{
  "name": "switchboard",
  "version": "0.1.26",
  "description": "The unified workspace for developers who run agents, terminals, and chats.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "prebuild": "npm run typecheck && npm test",
    "build": "electron-vite build",
    "postbuild": "node scripts/smoke-test.mjs",
    "build:fast": "electron-vite build",
    "preview": "unset ELECTRON_RUN_AS_NODE && electron-vite preview",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer",
    "lint": "eslint src/",
    "lint:deslop": "eslint src/",
    "prepare": "node scripts/install-hooks.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "rebuild": "npx --yes @electron/rebuild -f -w node-pty",
    "dist": "npm run build && electron-builder --mac --arm64",
    "dist:fast": "npm run build:fast && electron-builder --mac --arm64",
    "dist:arm64": "npm run build:fast && electron-builder --mac --arm64",
    "dist:x64": "npm run build:fast && electron-builder --mac --x64",
    "dist:mac": "npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:publish": "npm run build && electron-builder --mac --arm64 --publish always",
    "dist:publish:win": "npm run build && electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@effect/platform": "^0.96.0",
    "@lexical/react": "^0.44.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "cmdk": "^1.1.1",
    "effect": "^3.21.1",
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.1",
    "lexical": "^0.44.0",
    "marked": "^15.0.0",
    "node-pty": "^1.0.0",
    "shiki": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "lint-staged": "^16.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
